_format_version: "3.0"
_transform: true

upstreams:
- name: inventario_upstream
  algorithm: round-robin
  slots: 10000
  healthchecks:
    passive:
      type: http
      healthy:
        successes: 2
        http_statuses: [200, 201, 202, 204, 301, 302, 304]
      unhealthy:
        http_failures: 3
        tcp_failures: 3
        timeouts: 3
        http_statuses: [429, 500, 502, 503, 504]
  targets:
  - target: "inventario.__SERVICE_DISCOVERY_NAMESPACE__:3000"
    weight: __INVENTARIO_STABLE_WEIGHT__
  - target: "inventario-canary.__SERVICE_DISCOVERY_NAMESPACE__:3000"
    weight: __INVENTARIO_CANARY_WEIGHT__

- name: pedidos_upstream
  algorithm: round-robin
  slots: 10000
  healthchecks:
    passive:
      type: http
      healthy:
        successes: 2
        http_statuses: [200, 201, 202, 204, 301, 302, 304]
      unhealthy:
        http_failures: 3
        tcp_failures: 3
        timeouts: 3
        http_statuses: [429, 500, 502, 503, 504]
  targets:
  - target: "pedidos.__SERVICE_DISCOVERY_NAMESPACE__:3000"
    weight: __PEDIDOS_STABLE_WEIGHT__
  - target: "pedidos-canary.__SERVICE_DISCOVERY_NAMESPACE__:3000"
    weight: __PEDIDOS_CANARY_WEIGHT__

- name: envios_upstream
