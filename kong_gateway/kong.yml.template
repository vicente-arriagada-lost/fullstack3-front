  - target: "notificaciones-canary.__SERVICE_DISCOVERY_NAMESPACE__:3000"
    weight: __NOTIFICACIONES_CANARY_WEIGHT__

services:
- name: health_service
  host: 127.0.0.1
  port: 65535
  protocol: http
  routes:
  - name: health_route_root
    paths: ["/"]
    methods: ["GET"]
    strip_path: false
    plugins:
    - name: request-termination
      config:
        status_code: 200
        message: "ok"

- name: inventario_service
  host: inventario_upstream
  port: 80
  protocol: http
  path: /
  connect_timeout: 3000
  write_timeout: 15000
  read_timeout: 15000
  retries: 5
  routes:
  - name: inventario_route
    paths: ["/api/inventario"]
    methods: ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
    strip_path: false
    preserve_host: false

